<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    {# SEO Titles & Descriptions #}
    {% set seoTitle = title or ('seo.title' | i18n) %}
    {% set seoDesc = description or ('seo.description' | i18n) %}
    <title>{{ seoTitle }}{% if page.url != '/' and page.url != '/en/' and page.url != '/hu/' and page.url != '/ro/' %} - DAVID DEAK{% endif %}</title>
    <meta name="description" content="{{ seoDesc }}">
    
    {# Canonical & hreflang #}
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
    <link rel="alternate" hreflang="hu" href="{{ site.url }}/hu/">
    <link rel="alternate" hreflang="ro" href="{{ site.url }}/ro/">
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}/en/">

    {# Open Graph / Facebook #}
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:title" content="{{ seoTitle }}">
    <meta property="og:description" content="{{ seoDesc }}">
    <meta property="og:image" content="{{ site.url }}{{ image or '/assets/favicon.png' }}">

    {# Twitter #}
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta property="twitter:title" content="{{ seoTitle }}">
    <meta property="twitter:description" content="{{ seoDesc }}">
    <meta property="twitter:image" content="{{ site.url }}{{ image or '/assets/favicon.png' }}">

    <link rel="stylesheet" href="/style.css">
    <link rel="icon" href="/assets/favicon.png" type="image/png">
    
    {# Structured Data #}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "David Deak",
      "image": "{{ site.url }}{{ image or '/assets/favicon.png' }}",
      "@id": "{{ site.url }}",
      "url": "{{ site.url }}",
      "telephone": "",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Sfântu Gheorghe",
        "addressRegion": "Covasna",
        "addressCountry": "RO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 45.8606,
        "longitude": 25.7875
      },
      "areaServed": [
        {
          "@type": "AdministrativeArea",
          "name": "Covasna"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Transylvania"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Romania"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/davideak_/",
        "https://www.linkedin.com/in/david-deak-b1a43437b/"
      ],
      "jobTitle": "Graphic Designer, Videographer & Photographer",
      "knowsAbout": [
        "Graphic Design",
        "Event Photography",
        "Documentary Style Photography",
        "Videography",
        "Cinematic Video Production"
      ],
      "description": "{{ 'seo.description' | i18n }}"
    }
    </script>

    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="66922470-051e-4251-855b-e1d19d712825" data-blockingmode="auto" type="text/javascript"></script>
    
</head>
<body class="bg-black text-white ">
    <div id="loader" class="fixed h-screen inset-0 z-50 bg-black flex items-center justify-center">
        <div class="container">
          <div class="cube"><div class="cube__inner"></div></div>
          <div class="cube"><div class="cube__inner"></div></div>
          <div class="cube"><div class="cube__inner"></div></div>
        </div>
      </div>
    
    <div id="main" class="lg:ml-42 lg:mr-42 ml-10 mr-10 flex flex-col min-h-screen z-0 ">
        <!-- Header -->
        <div >
            {% include "header.njk" %}
        </div>

        <!-- Page Content -->
        <main class="flex-grow">
            {{ content | safe }}
        </main>

        <!-- Footer -->
        <footer class="mt-10">
            {% include "footer.njk" %}
        </footer>
    </div>
    <script>
        window.addEventListener('load', () => {
          document.getElementById('loader').style.display = 'none';
          document.getElementById('main').classList.remove('invisible');
        });

        if (window.netlifyIdentity) {
          window.netlifyIdentity.on("init", (user) => {
            if (!user) {
              window.netlifyIdentity.on("login", () => {
                document.location.href = "/admin/";
              });
            }
          });
        }
      </script>
</body>

</html>
